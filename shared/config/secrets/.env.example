# ============================================================
# Environment Variables Template
# ============================================================
# Copy this file to .env and fill in actual values.
# NEVER commit .env to version control.
# ============================================================

# --- Application ---
NODE_ENV=development
LOG_LEVEL=info
PORT=8080

# --- JWT Authentication ---
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7
JWT_PUBLIC_KEY_PATH=/etc/keys/jwt-public.pem
JWT_PRIVATE_KEY_PATH=/etc/keys/jwt-private.pem

# --- Database (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=assessment_dev
DB_USER=postgres
DB_PASSWORD=your-secure-db-password
DB_POOL_MAX_SIZE=10
DB_SSL_MODE=disable

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0
REDIS_SSL=false

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# --- AI Service ---
AI_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_ORGANIZATION=org-your-org-id
AI_MODEL=gpt-4o
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.3
AI_TIMEOUT_SECONDS=60

# --- OAuth / Third-party Auth ---
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
GITHUB_OAUTH_CLIENT_ID=your-github-client-id
GITHUB_OAUTH_CLIENT_SECRET=your-github-client-secret
GITHUB_OAUTH_APP_NAME=Real-Assessment-Platform

# --- Encryption ---
ENCRYPTION_KEY=your-32-byte-encryption-key-here
ENCRYPTION_ALGORITHM=AES-256-GCM

# --- Email Service (SMTP) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=noreply@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_USE_TLS=true
SMTP_FROM_NAME=Real Assessment Platform

# --- Storage (S3-compatible) ---
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-s3-access-key
S3_SECRET_ACCESS_KEY=your-s3-secret-key
S3_BUCKET_NAME=assessment-uploads
S3_CDN_URL=https://cdn.assessment.example.com

# --- Monitoring ---
PROMETHEUS_PORT=9090
JAEGER_ENDPOINT=jaeger-collector:4317
SENTRY_DSN=https://your-sentry-dsn
SENTRY_ENVIRONMENT=development

# --- Rate Limiting ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST_LIMIT=50

# --- Feature Flags ---
FEATURE_AI_SCORING=true
FEATURE_OAUTH=true
FEATURE_EMAIL_VERIFICATION=true
FEATURE_RATE_LIMITING=true
