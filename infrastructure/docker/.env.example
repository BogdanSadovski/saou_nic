# ===========================================
# Platform Environment Variables
# ===========================================
# Copy this file to .env and update with your values
# cp .env.example .env

# =====================
# General
# =====================
NODE_ENV=development
LOG_LEVEL=info

# =====================
# PostgreSQL
# =====================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secret_change_me
POSTGRES_DB=platform_db

# =====================
# Redis
# =====================
REDIS_PASSWORD=redis_secret_change_me

# =====================
# JWT Authentication
# =====================
JWT_SECRET=super_secret_jwt_key_change_in_production_minimum_32_chars
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# =====================
# OAuth - Google
# =====================
OAUTH_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
OAUTH_GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# =====================
# OAuth - GitHub
# =====================
OAUTH_GITHUB_CLIENT_ID=your-github-oauth-client-id
OAUTH_GITHUB_CLIENT_SECRET=your-github-oauth-client-secret

# =====================
# GitHub API
# =====================
GITHUB_CLIENT_ID=your-github-app-client-id
GITHUB_CLIENT_SECRET=your-github-app-client-secret
GITHUB_TOKEN=ghp_your-github-personal-access-token

# =====================
# LLM (Single Model For All AI Tasks)
# =====================
LLM_API_KEY=your-llm-api-key
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=

# =====================
# RabbitMQ
# =====================
RABBITMQ_DEFAULT_USER=rabbitmq_user
RABBITMQ_DEFAULT_PASS=rabbitmq_pass_change_me
RABBITMQ_DEFAULT_VHOST=/

# =====================
# ClickHouse
# =====================
CLICKHOUSE_DB=analytics
CLICKHOUSE_USER=clickhouse_user
CLICKHOUSE_PASSWORD=clickhouse_pass_change_me

# =====================
# S3 / MinIO (File Storage)
# =====================
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin_secret_change_me
S3_BUCKET=resumes

# =====================
# Email (SMTP)
# =====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM=noreply@platform.com

# =====================
# SendGrid (Alternative Email)
# =====================
SENDGRID_API_KEY=SG.your-sendgrid-api-key

# =====================
# Twilio (SMS Notifications)
# =====================
TWILIO_ACCOUNT_SID=AC_your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# =====================
# Grafana
# =====================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin_change_me

# =====================
# Service Ports (Customize if needed)
# =====================
USER_SERVICE_PORT=3001
RESUME_SERVICE_PORT=3002
GITHUB_SERVICE_PORT=3003
INTERVIEW_SERVICE_PORT=3004
AI_SERVICE_PORT=3006
SCORING_SERVICE_PORT=3007
REPORT_SERVICE_PORT=3008
NOTIFICATION_SERVICE_PORT=3009
ANALYTICS_SERVICE_PORT=3010
ADMIN_SERVICE_PORT=3011
API_GATEWAY_PORT=8000

# Infrastructure Ports
POSTGRES_PORT=5432
REDIS_PORT=6379
KAFKA_PORT=9092
KAFKA_EXTERNAL_PORT=29092
ZOOKEEPER_PORT=2181
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000

# Monitoring Ports
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
LOKI_PORT=3100
ALERTMANAGER_PORT=9093
NODE_EXPORTER_PORT=9100
CADVISOR_PORT=8081
